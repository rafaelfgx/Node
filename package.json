{
    "name": "node",
    "version": "1.0.0",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "update": "npx npm-check-updates -u",
        "check": "prettier . --check && eslint .",
        "fix": "prettier . --write && eslint . --fix",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "start": "tsx watch --env-file=.env src/main.ts",
        "build": "tsc -p tsconfig.build.json"
    },
    "imports": {
        "#src/*": "./dist/*"
    },
    "dependencies": {
        "cors": "2.8.6",
        "express": "5.2.1",
        "helmet": "8.1.0",
        "mongodb": "7.2.0",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/node": "25.6.0",
        "@types/supertest": "7.2.0",
        "@vitest/coverage-v8": "4.1.5",
        "eslint": "10.3.0",
        "eslint-config-prettier": "10.1.8",
        "globals": "17.6.0",
        "prettier": "3.8.3",
        "supertest": "7.2.2",
        "testcontainers": "11.14.0",
        "tsx": "4.21.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.2",
        "vitest": "4.1.5"
    }
}
